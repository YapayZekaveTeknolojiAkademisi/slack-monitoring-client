# Slack (zorunlu)
SLACK_APP_TOKEN=xapp-...

# Queue (prod’da mutlaka özelleştir; QUEUE_AUTHKEY varsayılan bırakılmamalı)
QUEUE_HOST=127.0.0.1
QUEUE_PORT=50000
QUEUE_AUTHKEY=your-secret-authkey-string

# API (opsiyonel; varsayılan 127.0.0.1:8000)
API_HOST=127.0.0.1
API_PORT=8002

# Opsiyonel
LOG_DIR=logs
ENV=production
